{
  "name": "teamitg-frontend-test",
  "description": "Frontend technical test for TeamITG - React 19, TypeScript, Vite, Storybook, atomic design",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetloose/teamitg-frontend-test"
  },
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm install && husky && npm run dev",
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint ./src && stylelint \"./src/**/*.scss\"",
    "lint:fix": "eslint ./src --fix && stylelint \"./src/**/*.scss\" --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint-staged": "lint-staged",
    "gen:component": "plop component",
    "git:branch": "node .scripts/git-branch.mjs",
    "git:commit": "node .scripts/git-commit.mjs",
    "git:pr": "node .scripts/git-pr.mjs",
    "watch:typescript": "tsc --noEmit --watch",
    "watch:eslint": "chokidar 'src/**/*.{ts,tsx}' -c 'eslint \"src/**/*.{ts,tsx}\"'",
    "watch:styles": "chokidar 'src/**/*.scss' -c 'stylelint \"src/**/*.scss\"'",
    "watch": "concurrently --names \"TypeScript,Eslint,Styles\" --prefix \"[{name}]\" --prefix-colors \"green,magenta,yellow\" \"npm run watch:typescript\" \"npm run watch:eslint\" \"npm run watch:styles\"",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.8",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "@vitest/coverage-v8": "3.2.6",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "eslint": "^9.21.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "meow": "9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^5.0.0",
    "react-hot-toast": "^2.5.2",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router": "^7.2.0",
    "react-router-dom": "^7.2.0",
    "sass": "^1.85.1",
    "stylelint-order": "^6.0.4",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "3.2.6",
    "vitest-canvas-mock": "^0.3.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.21.0",
    "@inquirer/prompts": "^8.5.2",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@stylistic/stylelint-plugin": "^3.1.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/browser": "3.2.6",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unicorn": "65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "plop": "^4.0.5",
    "prettier": "^3.5.3",
    "react-hook-form": "^7.54.2",
    "storybook": "^10.4.6",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0",
    "vite-plugin-eslint": "^1.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ],
    "*.scss": [
      "stylelint --fix"
    ]
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "trailingComma": "none"
  }
}
